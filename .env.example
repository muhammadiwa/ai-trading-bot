# AI Trading Bot Configuration
# Copy this file to .env and fill in your actual values

# Indodax API Configuration
INDODAX_API_KEY=your_indodax_api_key_here
INDODAX_SECRET_KEY=your_indodax_secret_key_here

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Twilio Configuration (for SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_FROM=your_twilio_phone_number_here
TWILIO_PHONE_TO=your_destination_phone_number_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+your_whatsapp_number_here

# Email Configuration (optional)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_password_here
EMAIL_TO=recipient@example.com

# Trading Parameters
STOP_LOSS_PERCENT=5
TAKE_PROFIT_PERCENT=15
MAX_DAILY_TRADES=20
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=0.05
RISK_PER_TRADE=0.02

# AI Model Configuration
LSTM_EPOCHS=50
BATCH_SIZE=32
PREDICTION_DAYS=7
SEQUENCE_LENGTH=60

# Database Configuration (if using database)
DATABASE_URL=sqlite:///trading_bot.db
DATABASE_TYPE=sqlite

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=trading_bot.log

# Backtesting Configuration
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=1000000

# Security Configuration
ENCRYPTION_KEY=your_encryption_key_here
API_RATE_LIMIT=100
SESSION_TIMEOUT=3600

# Development Settings
DEBUG=False
ENVIRONMENT=production
